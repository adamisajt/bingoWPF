<Window x:Class="bingoWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bingo" Height="350" Width="300">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- kartya -->
        <Button x:Name="btnGeneral"
                Grid.Row="0"
                Content="Kártya generálása"
                Margin="0,0,0,10"
                Height="30"
                Click="btnGeneral_Click"/>

        <!-- 5x5-->
        <UniformGrid x:Name="gridKartyak"
                     Grid.Row="1"
                     Rows="5"
                     Columns="5"
                     Margin="0,0,0,10"/>

        <!--nev/input -->
        <TextBox x:Name="txtFajlNev"
                 Grid.Row="2"
                 Text="bingo.txt"
                 Margin="0,0,0,10"
                 Height="25"/>

        <!-- mentes -->
        <Button x:Name="btnMentes"
                Grid.Row="3"
                Content="Mentés"
                Height="30"
                Click="btnMentes_Click"/>
    </Grid>
</Window>
